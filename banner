<!DOCTYPE html><html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MLBB Tournament Poster</title>
<style>
    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        font-family: Arial, sans-serif;
    }body{
    background:#0b0f1a;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

.poster{
    width:360px;
    height:680px;
    background: linear-gradient(180deg, #1a1f3c, #0b0f1a);
    border:2px solid #ffcc00;
    border-radius:20px;
    overflow:hidden;
    position:relative;
    color:white;
}

.header{
    text-align:center;
    padding:18px;
    background: rgba(255, 204, 0, 0.08);
}

.header h1{
    font-size:22px;
    color:#ffcc00;
    letter-spacing:2px;
}

.header p{
    font-size:12px;
    opacity:0.8;
}

.hero{
    text-align:center;
    margin-top:10px;
}

.hero img{
    width:85%;
    border-radius:12px;
    border:2px solid #ffcc00;
}

.info{
    padding:15px;
    text-align:center;
}

.info h2{
    color:#ffcc00;
    margin-bottom:8px;
    font-size:18px;
}

.price{
    font-size:18px;
    font-weight:bold;
    margin:6px 0;
    color:#00ffcc;
}

.box{
    background: rgba(255,255,255,0.05);
    margin:6px 0;
    padding:8px;
    border-radius:10px;
    font-size:13px;
}

.highlight{
    margin-top:8px;
    font-size:12px;
    opacity:0.9;
}

.btn{
    display:inline-block;
    margin-top:10px;
    padding:8px 18px;
    background:#ffcc00;
    color:#000;
    font-weight:bold;
    border-radius:10px;
    font-size:13px;
}

.footer{
    position:absolute;
    bottom:0;
    width:100%;
    padding:10px;
    text-align:center;
    background: rgba(0,0,0,0.5);
    font-size:11px;
}

</style>
</head>
<body><div class="poster"><div class="header">
    <h1>MLBB TOURNAMENT</h1>
    <p>Mobile Legends: Bang Bang Community Cup</p>
</div>

<div class="hero">
    <img src="https://images7.alphacoders.com/814/thumb-350-814885.webp" alt="MLBB Banner">
</div>

<div class="info">
    <h2>JOIN THE BATTLE!</h2>

    <div class="price">ENTRY: ₱50 PER TEAM</div>

    <div class="box">🏆 PRIZE POOL: ₱350 CASH</div>
    <div class="box">👥 TEAMS ALLOWED: 8 TEAMS ONLY</div>
    <div class="box">📜 DIGITAL CERTIFICATE FOR ALL PARTICIPANTS</div>
    <div class="box">⚔️ MATCH FORMAT: BO1 (1st) | BO2 (2nd) | BO3 (Final)</div>
    <div class="box">🔖 SHORT FORMAT: BO1 → BO2 → BO3</div>

    <div class="highlight">
        🔥 Fast Matches | 💥 Competitive Play | ⚔️ Fair Rules | 🎮 MLBB Classic Format
    </div>

    <div class="btn">REGISTER NOW</div>
</div>
    <br>
    <br>

<div class="footer">
   
    Contact Organizer | Location: TBD | Slots Limited
</div>

</div></body>
</html>
